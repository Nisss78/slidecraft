{
  "name": "slidecraft",
  "version": "0.1.0",
  "private": true,
  "description": "Local AI-powered slide generation tool with MCP server integration",
  "author": "SlideCraft Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/slidecraft/slidecraft.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
