{
  "name": "@slideharness/renderer",
  "version": "0.1.0",
  "description": "Slide Harness slide to HTML/CSS rendering engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@slideharness/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
