{
  "name": "@slidecraft/export",
  "version": "0.1.0",
  "description": "SlideCraft export engine (PDF, PNG, HTML)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@slidecraft/core": "workspace:*",
    "@slidecraft/renderer": "workspace:*",
    "pptxgenjs": "^3.12.0"
  },
  "optionalDependencies": {
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
