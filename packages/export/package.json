{
  "name": "@slideharness/export",
  "version": "0.1.0",
  "description": "Slide Harness export engine (PDF, PNG, HTML)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@slideharness/core": "workspace:*",
    "@slideharness/renderer": "workspace:*",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.59.1",
    "pptxgenjs": "^3.12.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
